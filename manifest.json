{
  "version": "0.2.0",
  "name": "RoleDeck — AWS role switcher",
  "description": "RoleDeck: a faster, safer way to switch AWS IAM roles — color-coded Firefox containers, production guardrails, favorites & recents, session auto-renew, and a command-palette popup. Configure it like an aws config file.",
  "short_name": "RoleDeck",
  "icons" : {
    "48": "icons/roledeck-hat-48.png",
    "128": "icons/roledeck-hat-128.png"
  },
  "action": {
    "default_title": "RoleDeck",
    "default_icon": {
      "16": "icons/roledeck-hat-16.png",
      "32": "icons/roledeck-hat-32.png",
      "38": "icons/roledeck-hat-38.png",
      "48": "icons/roledeck-hat-48.png"
    },
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Comma"
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.console.aws.amazon.com/*",
        "https://health.aws.amazon.com/*",
        "https://lightsail.aws.amazon.com/*",
        "https://*.console.amazonaws-us-gov.com/*",
        "https://phd.amazonaws-us-gov.com/*",
        "https://*.console.amazonaws.cn/*",
        "https://health.amazonaws.cn/*"
      ],
      "js": [
        "js/content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.signin.aws.amazon.com/switchrole*",
        "https://signin.aws.amazon.com/switchrole*",
        "https://*.signin.amazonaws-us-gov.com/switchrole*",
        "https://signin.amazonaws-us-gov.com/switchrole*",
        "https://signin.amazonaws.cn/switchrole*"
      ],
      "js": [
        "js/switchrole_auto.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [{
    "resources": ["js/war/attach_target.js", "js/war/prism_switch_dest.js"],
    "matches": [
      "https://*.console.aws.amazon.com/*",
      "https://health.aws.amazon.com/*",
      "https://lightsail.aws.amazon.com/*",
      "https://*.console.amazonaws-us-gov.com/*",
      "https://phd.amazonaws-us-gov.com/*",
      "https://*.console.amazonaws.cn/*",
      "https://health.amazonaws.cn/*"
    ]
  }],
  "manifest_version": 3
}
